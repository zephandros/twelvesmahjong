{
  "name": "twelves-mahjong",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Mahjong Twelves (麻雀トウェルブス) — single-player offline riichi mahjong",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "assets:tiles": "node scripts/build-tiles.mjs",
    "assets:fonts": "node scripts/fetch-fonts.mjs && python scripts/subset-murecho.py && python scripts/subset-jp.py",
    "assets:audio": "node scripts/build-audio.mjs"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "svgo": "^4.0.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^3.2.4"
  }
}
